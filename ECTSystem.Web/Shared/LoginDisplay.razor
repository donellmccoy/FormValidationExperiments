@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject CurrentUserService CurrentUser
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <div class="login-display">
            <RadzenIcon Icon="account_circle" class="user-icon" />
            <div class="user-info">
                <span class="user-name">@(_fullName ?? context.User.Identity?.Name)</span>
                @if (!string.IsNullOrWhiteSpace(_role))
                {
                    <span class="user-role-separator">·</span>
                    <span class="user-role">@_role</span>
                }
            </div>
            <RadzenButton Text="Logout"
                          Icon="logout"
                          ButtonStyle="ButtonStyle.Light"
                          Variant="Variant.Text"
                          Size="ButtonSize.Small"
                          Click="@OnLogout" />
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="login-display">
            <RadzenButton Text="Sign In"
                          Icon="login"
                          ButtonStyle="ButtonStyle.Primary"
                          Variant="Variant.Text"
                          Size="ButtonSize.Small"
                          Click="@(() => Navigation.NavigateTo("/login"))" />
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _fullName;
    private string _role;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        await LoadUserInfoIfAuthenticatedAsync();
    }

    private async Task LoadUserInfoIfAuthenticatedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User?.Identity?.IsAuthenticated != true)
        {
            _fullName = null;
            _role = null;
            return;
        }

        var info = await CurrentUser.GetUserInfoAsync();
        if (info is not null)
        {
            _fullName = string.IsNullOrWhiteSpace(info.FullName) ? info.Name : info.FullName;
            _role = info.Role;
        }
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        _ = InvokeAsync(async () =>
        {
            await LoadUserInfoIfAuthenticatedAsync();
            StateHasChanged();
        });
    }

    private async Task OnLogout()
    {
        // AuthService.LogoutAsync centrally clears tokens and redirects to /login with a full reload.
        await AuthService.LogoutAsync();
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}
