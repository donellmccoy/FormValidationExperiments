<p class="rz-mb-4">Do you want to check out Case <strong>@CaseId</strong> for editing?</p>

<div style="display: flex; gap: 8px; justify-content: flex-end;">
    <RadzenSplitButton Text="Check Out" Click="@OnCheckOut" ButtonStyle="ButtonStyle.Primary">
        <ChildContent>
            <RadzenSplitButtonItem Text="Check Out Read-Only" Value="readonly" Icon="visibility" />
        </ChildContent>
    </RadzenSplitButton>
    <RadzenButton Text="Cancel" Click="@(() => DialogService.Close(null))" ButtonStyle="ButtonStyle.Light" />
</div>
