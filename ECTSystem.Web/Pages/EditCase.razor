                                                      Click="@RefreshCaseHistoryGrid" title="Refresh case history" />
                                    </RadzenStack>

                                    <RadzenDataGrid @ref="_previousCasesGrid" TItem="LineOfDutyCase"
                                                    Data="@_previousCases"
                                                    Count="@_previousCasesCount"
                                                    LoadData="@LoadPreviousCasesData"
                                                    IsLoading="@_previousCasesLoading"
                                                    SelectionMode="DataGridSelectionMode.Single"
                                                    @bind-Value="@_selectedPreviousCase"
                                                    AllowRowSelectOnRowClick="true"
                                                    AllowSorting="true"
                                                    AllowColumnResize="true"
                                                    FilterMode="FilterMode.Simple"
                                                    PageSize="10"
                                                    AllowPaging="true"
                                                    PagerHorizontalAlign="HorizontalAlign.Center"
                                                    GridLines="DataGridGridLines.Both"
                                                    CellContextMenu="@OnPreviousCaseCellContextMenu"
                                                    class="rz-border-radius-2">
                                        <EmptyTemplate>
                                            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-py-12">
                                                <RadzenIcon Icon="history" Style="font-size: 48px; color: var(--rz-text-disabled-color);" />
                                                <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                                                    No previous cases found for this member.
                                                </RadzenText>
                                            </RadzenStack>
                                        </EmptyTemplate>
                                        <Columns>
                                            <RadzenDataGridColumn TItem="LineOfDutyCase" Title="" Width="55px" Sortable="false" Filterable="false" Resizable="false" Reorderable="false" Groupable="false" TextAlign="TextAlign.Center">
                                                <Template Context="lodCase">
                                                    @if (lodCase.IsCheckedOut)
                                                    {
                                                        @if (string.Equals(lodCase.CheckedOutBy, _currentUserId, StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <RadzenIcon Icon="check_circle" Style="font-size: 16px; color: var(--rz-success);" title="Checked out by you" />
                                                        }
                                                        else
                                                        {
                                                            <RadzenIcon Icon="lock" class="checkout-lock-icon" Style="font-size: 16px;" title="@($"Checked out by {lodCase.CheckedOutByName}")" />
                                                        }
                                                    }
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="LineOfDutyCase" Property="CaseId" Title="Case ID" Width="180px">
                                                <Template Context="lodCase">
                                                    <div class="case-id-cell">
                                                        <span class="case-id-link" @onclick="@(() => OnPreviousCaseClick(lodCase))">
                                                            @lodCase.CaseId
                                                        </span>
                                                        <RadzenButton ButtonStyle="ButtonStyle.Light"
                                                                      Variant="Variant.Text"
                                                                      Size="ButtonSize.ExtraSmall"
                                                                      class="bookmark-btn"
                                                                      Click="@(() => TogglePreviousBookmark(lodCase))"
                                                                      title="@(_previousCasesBookmarkedIds.Contains(lodCase.Id) ? "Remove Bookmark" : "Add Bookmark")">
                                                            <ChildContent>
                                                                <span class="material-symbols-outlined @(_previousCasesAnimatingIds.Contains(lodCase.Id) ? "bookmark-flash" : "")">@(_previousCasesBookmarkedIds.Contains(lodCase.Id) ? "bookmark_remove" : "bookmark_add")</span>
                                                            </ChildContent>
                                                        </RadzenButton>
                                                    </div>
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="LineOfDutyCase" Property="Unit" Title="Unit" />
                                            <RadzenDataGridColumn TItem="LineOfDutyCase" Title="Status" Sortable="false" Filterable="false">
                                                <Template Context="lodCase">
                                                    @lodCase.GetCurrentWorkflowState().ToDisplayString()
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="LineOfDutyCase" Property="InitiationDate" Title="Created" Width="120px">
                                                <Template Context="lodCase">
                                                    @(lodCase.InitiationDate > DateTime.MinValue ? lodCase.InitiationDate.ToString("yyyy-MM-dd") : "")
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="LineOfDutyCase" Property="CompletionDate" Title="Completed" Width="120px">
                                                <Template Context="lodCase">
                                                    @(lodCase.CompletionDate.HasValue ? lodCase.CompletionDate.Value.ToString("yyyy-MM-dd") : "No")
                                                </Template>
                                            </RadzenDataGridColumn>
                                        </Columns>
                                    </RadzenDataGrid>
                                </RadzenStack>
                                </RadzenPanel>
                            </ChildContent>
                        </RadzenTabsItem>
                        @* ─── Tracking History Tab ─── *@
                        <RadzenTabsItem Text="Tracking History">
                            <Template>
                                <span class="tab-label">
                                    Tracking History
                                </span>
                            </Template>
                            <ChildContent>
                                <RadzenPanel AllowCollapse="false" Style="width:1135px; height:1125px" class="assessment-panel rz-border-primary-lighter rz-border-radius-2 rz-overflow-hidden">
                                <RadzenStack class="rz-p-4" Gap="1rem">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                        <RadzenTextBox @ref="_trackingSearchBox"
                                                       Value="@_trackingSearchText"
                                                       @oninput="@OnTrackingSearchInput"
                                                       Placeholder="Search tracking history..."
                                                       Style="width: 50%;" />
                                        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Variant="Variant.Text"
                                                      Click="@RefreshTrackingGrid" title="Refresh tracking history" />
                                    </RadzenStack>

                                    <RadzenDataGrid @ref="_trackingGrid" TItem="WorkflowStateHistory"
                                                    Data="@_trackingData"
                                                    LoadData="@LoadTrackingData"
                                                    Count="@_trackingCount"
                                                    IsLoading="@_trackingLoading"
                                                    SelectionMode="DataGridSelectionMode.Single"
                                                    @bind-Value="@_selectedTrackingEntry"
                                                    AllowRowSelectOnRowClick="true"
                                                    AllowSorting="true"
                                                    AllowColumnResize="true"
                                                    AllowPaging="true"
                                                    PageSize="10"
                                                    PagerHorizontalAlign="HorizontalAlign.Center"
                                                    GridLines="DataGridGridLines.Both"
                                                    class="rz-border-radius-2">
                                        <EmptyTemplate>
                                            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-py-12">
                                                <RadzenIcon Icon="timeline" Style="font-size: 48px; color: var(--rz-text-disabled-color);" />
                                                <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                                                    No tracking history entries found.
                                                </RadzenText>
                                            </RadzenStack>
                                        </EmptyTemplate>
                                        <Columns>
                                            <RadzenDataGridColumn TItem="WorkflowStateHistory" Property="WorkflowState" Title="Status">
                                                <Template Context="entry">
                                                    @entry.WorkflowState.ToDisplayString()
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="WorkflowStateHistory" Property="EnteredDate" Title="Entered" Width="180px" FormatString="{0:MM/dd/yyyy h:mm tt}" />
                                            <RadzenDataGridColumn TItem="WorkflowStateHistory" Property="ExitDate" Title="Exited" Width="180px">
                                                <Template Context="entry">
                                                    @(entry.ExitDate.HasValue ? entry.ExitDate.Value.ToString("MM/dd/yyyy h:mm tt") : "In Progress")
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="WorkflowStateHistory" Property="CreatedDate" Title="Date" Width="180px" FormatString="{0:MM/dd/yyyy h:mm tt}" />
                                        </Columns>
                                    </RadzenDataGrid>
                                </RadzenStack>
                                </RadzenPanel>
                            </ChildContent>
                        </RadzenTabsItem>
                    </Tabs>
                </RadzenTabs>
            </RadzenStack>
        </RadzenStack>
    </div>
}

