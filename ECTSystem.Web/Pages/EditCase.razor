                                                                </RadzenFormField>
                                                            </RadzenStack>
                                                        </RadzenFieldset>

                                                        @* ═══ Fieldset D: Item 19 — Misconduct Assessment ═══ *@
                                                        <RadzenFieldset Text="Misconduct Assessment" class="rz-mt-4 arc-fieldset">
                                                            <RadzenStack Gap="1rem">
