                        @* ─── Case Dialogue Tab ─── *@
                        <RadzenTabsItem Text="Case Dialogue">
                            <Template>
                                <span class="tab-label">Case Dialogue</span>
                            </Template>
                            <ChildContent>
                                <RadzenPanel AllowCollapse="false" Style="width:1135px; height:1125px" class="assessment-panel rz-border-primary-lighter rz-border-radius-2 rz-overflow-hidden">
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-p-4 rz-color-secondary">
                                    Case dialogue and communication thread between stakeholders will be presented here.
                                </RadzenText>
                                </RadzenPanel>
                            </ChildContent>
                        </RadzenTabsItem>
                        @* ─── Notifications Tab ─── *@
                        <RadzenTabsItem Text="Notifications">
                            <Template>
                                <span class="tab-label">
                                    Notifications
                                    @if (NotificationCount > 0)
                                    {
                                        <RadzenBadge Text="@NotificationCount.ToString()" BadgeStyle="BadgeStyle.Info" IsPill="true" class="rz-ml-1" />
                                    }
                                </span>
                            </Template>
                            <ChildContent>
                                <RadzenPanel AllowCollapse="false" Style="width:1135px; height:1125px" class="assessment-panel rz-border-primary-lighter rz-border-radius-2 rz-overflow-hidden">
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-p-4 rz-color-secondary">
                                    Notifications for this LOD case will be presented here.
                                </RadzenText>
                                </RadzenPanel>
                            </ChildContent>
                        </RadzenTabsItem>
                        @* ─── Documents Tab ─── *@
                        <RadzenTabsItem Text="Documents">
                            <Template>
                                <span class="tab-label">
                                    Documents
                                    @if (DocumentCount > 0)
                                    {
                                        <RadzenBadge Text="@DocumentCount.ToString()" BadgeStyle="BadgeStyle.Info" IsPill="true" class="rz-ml-1" />
                                    }
                                </span>
                            </Template>
                            <ChildContent>
                                <RadzenPanel AllowCollapse="false" Style="width:1135px; height:1125px" class="assessment-panel rz-border-primary-lighter rz-border-radius-2 rz-overflow-hidden">
                                <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" class="rz-p-4">
                                    @* ═══ File Upload Section ═══ *@
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                        <RadzenTextBox @ref="_documentsSearchBox"
                                                       Value="@_documentsSearchText"
                                                       @oninput="@OnDocumentsSearchInput"
                                                       Placeholder="Search documents..."
                                                       Style="width: 50%;" />
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                        <RadzenUpload Url="@($"{Http.BaseAddress}odata/Cases({_lineOfDutyCase?.Id})/Documents")"
                                                      Auto="true"
                                                      Multiple="true"
                                                      ParameterName="file"
                                                      ChooseText="Choose Files"
                                                      Accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.txt"
                                                      MaxFileSize="10000000"
                                                      Disabled="@(_lineOfDutyCase?.Id is null or 0)"
                                                      Progress="@OnUploadProgress"
                                                      Complete="@OnUploadComplete"
                                                      Error="@OnUploadError">
                                            <RadzenUploadHeader Name="Authorization" Value="@_documents.AuthToken" />
                                        </RadzenUpload>
                                        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                                      Variant="Variant.Text" Click="@RefreshDocumentsAsync"
                                                      title="Refresh documents" />
                                        </RadzenStack>
                                    </RadzenStack>

                                    @* ═══ Upload Progress ═══ *@
                                    @if (_documents.IsUploading)
                                    {
                                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.25rem" class="upload-progress-bar">
                                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                                    @if (!string.IsNullOrEmpty(_documents.UploadFileName))
                                                    {
                                                        <text>Uploading @_documents.UploadFileName…</text>
                                                    }
                                                    else
                                                    {
                                                        <text>Uploading…</text>
                                                    }
                                                </RadzenText>
                                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                                    @(_documents.UploadProgress)%
                                                </RadzenText>
                                            </RadzenStack>
                                            <RadzenProgressBar Value="@_documents.UploadProgress" ShowValue="false"
                                                               Style="width: 100%; height: 6px;"
                                                               ProgressBarStyle="ProgressBarStyle.Primary" />
                                        </RadzenStack>
                                    }

                                    @* ═══ Documents Data Grid ═══ *@
                                    <RadzenDataGrid @ref="_documentsGrid" TItem="LineOfDutyDocument"
                                                    Data="@_documentsData"
                                                    LoadData="@LoadDocumentsData"
                                                    Count="@_documentsCount"
                                                    IsLoading="@_documents.IsLoading"
                                                    AllowSorting="true"
                                                    AllowColumnResize="true"
                                                    AllowPaging="true"
                                                    PageSize="10"
                                                    PagerHorizontalAlign="HorizontalAlign.Center"
                                                    GridLines="DataGridGridLines.Both"
                                                    class="rz-border-radius-2">
                                        <EmptyTemplate>
                                            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-py-12">
                                                <RadzenIcon Icon="description" Style="font-size: 48px; color: var(--rz-text-disabled-color);" />
                                                <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                                                    No documents to display.
                                                </RadzenText>
                                            </RadzenStack>
                                        </EmptyTemplate>
                                        <Columns>
                                            <RadzenDataGridColumn TItem="LineOfDutyDocument" Property="FileName" Title="File Name">
                                                <Template Context="doc">
                                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="width: 100%;">
                                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                            <RadzenIcon Icon="@GetDocumentIcon(doc.FileName)" Style="color: var(--rz-text-tertiary-color);" />
                                                            <span @onclick="@(() => OnDownloadDocumentAsync(doc))"
                                                                  class="doc-file-link">@doc.FileName</span>
                                                        </RadzenStack>
                                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" class="doc-actions">
                                                            <RadzenButton Icon="open_in_new" ButtonStyle="ButtonStyle.Info"
                                                                          Variant="Variant.Text" Size="ButtonSize.Small"
                                                                          Click="@(() => OnViewDocumentInBrowserAsync(doc))"
                                                                          title="View in browser" />
                                                            <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Info"
                                                                          Variant="Variant.Text" Size="ButtonSize.Small"
                                                                          Click="@(() => OnDownloadDocumentAsync(doc))"
                                                                          title="Download" />
                                                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger"
                                                                          Variant="Variant.Text" Size="ButtonSize.Small"
                                                                          Click="@(() => OnDeleteDocumentAsync(doc))" />
                                                        </RadzenStack>
                                                    </RadzenStack>
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="LineOfDutyDocument" Property="UploadDate" Title="Uploaded" Width="180px">
                                                <Template Context="doc">
                                                    @(doc.UploadDate?.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt") ?? "")
                                                </Template>
                                            </RadzenDataGridColumn>
                                            <RadzenDataGridColumn TItem="LineOfDutyDocument" Property="CreatedBy" Title="By" Width="180px">
                                                <Template Context="doc">
                                                    @GetUserDisplayName(doc.CreatedBy)
                                                </Template>
                                            </RadzenDataGridColumn>
                                        </Columns>
                                    </RadzenDataGrid>
                                </RadzenStack>
                                </RadzenPanel>
                            </ChildContent>
                        </RadzenTabsItem>
                        @* ─── Form 348 Tab ─── *@
                        <RadzenTabsItem Text="AF Form 348">
                            <Template>
                                <span class="tab-label">
                                    AF Form 348
                                </span>
                            </Template>
                            <ChildContent>
                                <RadzenPanel AllowCollapse="false" Style="width:1135px; height:1125px" class="assessment-panel rz-border-primary-lighter rz-border-radius-2 rz-overflow-hidden">
                                <div class="form348-viewer-container">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                                 JustifyContent="JustifyContent.End"
                                                 Gap="0.5rem" class="rz-p-2 form348-toolbar">
                                        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light"
                                                      Size="ButtonSize.Small" Click="@LoadForm348Async"
                                                      Variant="Variant.Text" Disabled="@isLoadingForm348" />
                                    </RadzenStack>
                                    @if (!string.IsNullOrEmpty(form348Error))
                                    {
                                        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" class="rz-m-4">
                                            @form348Error
                                        </RadzenAlert>
                                        <RadzenButton Text="Retry" Icon="refresh" ButtonStyle="ButtonStyle.Secondary"
                                                      Click="@LoadForm348Async" class="rz-ml-4" />
                                    }
                                    else if (isLoadingForm348)
                                    {
                                        <RadzenSkeleton Style="width: 100%; flex: 1;" Animation="SkeletonAnimation.Wave" />
                                    }
                                    else
                                    {
                                        <iframe src="@form348DataUrl" class="form348-iframe"></iframe>
                                    }
                                </div>
                                </RadzenPanel>
                            </ChildContent>
                        </RadzenTabsItem>
                        @* ─── Case History Tab ─── *@
                        <RadzenTabsItem Text="Case History">
                            <Template>
                                <span class="tab-label">
                                    Case History
                                </span>
                            </Template>
                            <ChildContent>
                                <RadzenPanel AllowCollapse="false" Style="width:1135px; height:1125px" class="assessment-panel rz-border-primary-lighter rz-border-radius-2 rz-overflow-hidden">
                                <RadzenStack class="rz-p-4 previous-cases-content" Gap="1rem">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                        <RadzenTextBox @ref="_previousCasesSearchBox"
                                                       Value="@_previousCasesSearchText"
                                                       @oninput="@OnPreviousCasesSearchInput"
                                                       Placeholder="Search previous cases..."
                                                       Style="width: 50%;" />
