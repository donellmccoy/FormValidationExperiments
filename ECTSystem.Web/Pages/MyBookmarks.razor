@page "/bookmarks"
@attribute [Authorize]

<PageTitle>My Bookmarks - Electronic Case Tracking System</PageTitle>

<div class="rz-p-0 rz-p-md-4">
@if (!_initialLoadComplete)
{
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center"
                      class="rz-mb-4">
            <RadzenSkeleton Style="width: 51%; height: 36px;" class="rz-border-radius-1" Animation="SkeletonAnimation.Wave" />
            <RadzenSkeleton Style="width: 130px; height: 36px;" class="rz-border-radius-1" Animation="SkeletonAnimation.Wave" />
        </RadzenStack>
        <RadzenStack Gap="0.5rem" class="rz-border-radius-2 rz-p-4">
            <RadzenSkeleton Style="width: 100%; height: 40px;" Animation="SkeletonAnimation.Wave" />
            @for (var i = 0; i < 5; i++)
            {
                <RadzenSkeleton Style="width: 100%; height: 36px;" Animation="SkeletonAnimation.Wave" />
            }
        </RadzenStack>
    </RadzenStack>
}

<div style="@(!_initialLoadComplete ? "visibility:hidden;overflow:hidden;height:0" : "")">

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center"
              class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="width: 51%;">
        <RadzenTextBox @ref="_searchBox" Value="@_searchText"
                       @oninput="@OnSearchInput"
                       Placeholder="Search bookmarked cases..." Style="width: 100%;" />
        <RadzenIcon Icon="info" Style="font-size: 20px; color: var(--rz-text-secondary-color); cursor: help;"
                    MouseEnter="@ShowSearchTooltip"
                    MouseLeave="@(_ => TooltipService.Close())" />
    </RadzenStack>
    <RadzenButton Text="Create Case" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Variant="Variant.Outlined" Click="@OnCreateCase" />
</RadzenStack>

<RadzenDataGrid @ref="_grid" TItem="LineOfDutyCase"
                Data="@_bookmarks"
                Count="@_count"
                LoadData="@LoadData"
                IsLoading="@_isLoading"
                SelectionMode="DataGridSelectionMode.Multiple"
                AllowRowSelectOnRowClick="true"
                @bind-Value="_selectedBookmarks"
                AllowSorting="true"
                AllowFiltering="true"
                AllowGrouping="true" 
                AllowColumnResize="true"
                FilterMode="FilterMode.Simple"
                PageSize="10"
                AllowPaging="true"
                ShowPagingSummary="true"
                PagingSummaryFormat="@("Displaying page {0} of {1} ({2} records)")"
                PageSizeOptions="@(new[] { 5, 10, 25, 50 })"
                PagerHorizontalAlign="HorizontalAlign.Center"
                GridLines="DataGridGridLines.Both"
                CellContextMenu="@OnCellContextMenu"
                class="rz-border-radius-2">
    <EmptyTemplate>
        <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-py-12">
            <RadzenIcon Icon="bookmarks" Style="font-size: 48px; color: var(--rz-text-disabled-color);" />
            <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                No bookmarked cases yet. Open a case and click the bookmark icon to save it here.
            </RadzenText>
        </RadzenStack>
    </EmptyTemplate>
    <Columns>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Title="" Width="55px" Sortable="false" Filterable="false" Resizable="false" Reorderable="false" Groupable="false" TextAlign="TextAlign.Center" >
            <Template Context="lodCase">
                @if (lodCase.IsCheckedOut)
                {
                    @if (string.Equals(lodCase.CheckedOutBy, _currentUserId, StringComparison.OrdinalIgnoreCase))
                    {
                        <RadzenIcon Icon="check_circle" Style="font-size: 16px; color: var(--rz-success);" title="Checked out by you" />
                    }
                    else
                    {
                        <RadzenIcon Icon="lock" class="checkout-lock-icon" Style="font-size: 16px;" title="@($"Checked out by {lodCase.CheckedOutByName}")" />
                    }
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="CaseId" Title="Case Number" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                <div class="case-id-cell">
                    <span class="case-id-link" @onclick="@(() => OnCaseClick(lodCase))">
                        @lodCase.CaseId
                    </span>
                    <RadzenButton ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Text"
                                  Size="ButtonSize.Medium"
                                  class="bookmark-btn"
                                  title="Remove bookmark"
                                  Click="@(() => OnRemoveBookmark(lodCase))">
                        <ChildContent>
                            <span class="material-symbols-outlined">bookmark_remove</span>
                        </ChildContent>
                    </RadzenButton>
                </div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="ServiceNumber" Title="SSN" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @if (!string.IsNullOrEmpty(lodCase.ServiceNumber) && lodCase.ServiceNumber.Length >= 4)
                {
                    @($"{lodCase.ServiceNumber[^4..]}")
                }
                else
                {
                    @lodCase.ServiceNumber
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="MemberName" Title="Member Name" TextAlign="TextAlign.Center"/>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="MemberRank" Title="Rank" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="Unit" Title="Unit" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="LineOfDutyCase" Title="Current Status" TextAlign="TextAlign.Center" Sortable="false">
            <Template Context="lodCase">
                @lodCase.GetCurrentWorkflowState().ToDisplayString()
            </Template>
            <FilterTemplate>
                <RadzenDropDown @bind-Value="_workflowStateFilter"
                                Data="@_workflowStateFilters"
                                TextProperty="Text"
                                ValueProperty="Value"
                                AllowClear="true"
                                Style="width:100%"
                                PopupStyle="max-height:200px; overflow-y:auto"
                                Change="@(args => _grid.Reload())" />
            </FilterTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="IncidentType" Title="Injury Type" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @lodCase.IncidentType.ToDisplayString()
            </Template>
            <FilterTemplate>
                <RadzenDropDown @bind-Value="_incidentTypeFilter"
                                Data="@_incidentTypeFilters"
                                TextProperty="Text"
                                ValueProperty="Value"
                                AllowClear="true"
                                Style="width:100%"
                                PopupStyle="max-height:200px; overflow-y:auto"
                                Change="@(args => _grid.Reload())" />
            </FilterTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="IncidentDate" Title="Date of Incident" FormatString="{0:yyyy-MM-dd}" TextAlign="TextAlign.Center"/>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="ProcessType" Title="Process Type" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @lodCase.ProcessType.ToDisplayString()
            </Template>
            <FilterTemplate>
                <RadzenDropDown @bind-Value="_processTypeFilter"
                                Data="@_processTypeFilters"
                                TextProperty="Text"
                                ValueProperty="Value"
                                AllowClear="true"
                                Style="width:100%"
                                PopupStyle="max-height:200px; overflow-y:auto"
                                Change="@(args => _grid.Reload())" />
            </FilterTemplate>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

</div>
</div>
