@page "/cases"
@attribute [Authorize]

<PageTitle>Cases - Electronic Case Tracking System</PageTitle>

<div class="rz-p-0 rz-p-md-4">
@if (isLoading && cases == null)
{
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center"
                      class="rz-mb-4">
            <RadzenSkeleton Style="width: 240px; height: 32px;" Animation="SkeletonAnimation.Wave" />
            <RadzenSkeleton Style="width: 130px; height: 36px;" class="rz-border-radius-1" Animation="SkeletonAnimation.Wave" />
        </RadzenStack>
        <RadzenSkeleton Style="width: 100%; height: 40px;" class="rz-border-radius-1 rz-mb-4" Animation="SkeletonAnimation.Wave" />
        <RadzenStack Gap="0.5rem" class="rz-border-radius-2 rz-p-4">
            <RadzenSkeleton Style="width: 100%; height: 40px;" Animation="SkeletonAnimation.Wave" />
            @for (var i = 0; i < 5; i++)
            {
                <RadzenSkeleton Style="width: 100%; height: 36px;" Animation="SkeletonAnimation.Wave" />
            }
        </RadzenStack>
    </RadzenStack>
}
else
{

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center"
              class="rz-mb-4">
    <RadzenTextBox Value="@searchText"
                   @oninput="@OnSearchInput"
                   Placeholder="Search cases..." Style="width: 51%;" />
    <RadzenButton Text="Create Case" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Variant="Variant.Outlined" Click="@OnCreateCase" />
</RadzenStack>

<RadzenDataGrid @ref="_grid" TItem="LineOfDutyCase"
                Data="@cases"
                Count="@count"
                LoadData="@LoadData"
                IsLoading="@isLoading"
                SelectionMode="DataGridSelectionMode.Single"
                AllowRowSelectOnRowClick="true"
                @bind-Value="_selectedCases"
                CellContextMenu="@OnCellContextMenu"
                AllowSorting="true"
                AllowFiltering="true"
                AllowGrouping="true" 
                AllowColumnResize="true"
                FilterMode="FilterMode.Simple"
                PageSize="10"
                AllowPaging="true"
                ShowPagingSummary="true"
                PagingSummaryFormat="@("Displaying page {0} of {1} ({2} records)")"
                PageSizeOptions="@(new[] { 5, 10, 25, 50 })"
                PagerHorizontalAlign="HorizontalAlign.Center"
                GridLines="DataGridGridLines.Both"
                class="rz-border-radius-2">
    <EmptyTemplate>
        <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-py-12">
            <RadzenIcon Icon="list" Style="font-size: 48px; color: var(--rz-text-disabled-color);" />
            <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                No cases yet. Click the Create Case button to start a new case.
            </RadzenText>
        </RadzenStack>
    </EmptyTemplate>
    <Columns>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="CaseId" Title="Case ID" Width="180px">
            <Template Context="lodCase">
                <div class="case-id-cell">
                    <RadzenLink Path="@($"case/{lodCase.CaseId}?from=cases")" Text="@lodCase.CaseId" />
                    <RadzenButton Icon="@(bookmarkedCaseIds.Contains(lodCase.Id) ? "bookmark_remove" : "bookmark_add")"
                                  ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Text"
                                  Size="ButtonSize.ExtraSmall"
                                  class="bookmark-btn"
                                  Click="@(() => ToggleBookmark(lodCase))"
                                  title="@(bookmarkedCaseIds.Contains(lodCase.Id) ? "Remove Bookmark" : "Add Bookmark")" />
                </div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="ServiceNumber" Title="SSN" Width="120px">
            <Template Context="lodCase">
                @if (!string.IsNullOrEmpty(lodCase.ServiceNumber) && lodCase.ServiceNumber.Length >= 4)
                {
                    @($"***-**-{lodCase.ServiceNumber[^4..]}")
                }
                else
                {
                    @lodCase.ServiceNumber
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="MemberName" Title="Member" Width="220px" />
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="MemberRank" Title="Rank" Width="85px" TextAlign="TextAlign.Center"/>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="Unit" Title="Unit"  />
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="WorkflowState" Title="Status">
            <Template Context="lodCase">
                @lodCase.WorkflowState.ToDisplayString()
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="IncidentType" Title="Type">
            <Template Context="lodCase">
                @lodCase.IncidentType.ToDisplayString()
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="IncidentDate" Title="Incident Date" FormatString="{0:yyyy-MM-dd}" />
        <RadzenDataGridColumn TItem="LineOfDutyCase" Property="ProcessType" Title="Process">
            <Template Context="lodCase">
                @lodCase.ProcessType.ToDisplayString()
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

}
</div>
