@page "/cases"
@attribute [Authorize]

<PageTitle>Cases - Electronic Case Tracking System</PageTitle>

<div class="rz-p-0 rz-p-md-4">
@if (!_initialLoadComplete)
{
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center"
                      class="rz-mb-4">
            <RadzenSkeleton Style="width: 51%; height: 36px;" class="rz-border-radius-1" Animation="SkeletonAnimation.Wave" />
            <RadzenSkeleton Style="width: 130px; height: 36px;" class="rz-border-radius-1" Animation="SkeletonAnimation.Wave" />
        </RadzenStack>
        <RadzenStack Gap="0.5rem" class="rz-border-radius-2 rz-p-4">
            <RadzenSkeleton Style="width: 100%; height: 40px;" Animation="SkeletonAnimation.Wave" />
            @for (var i = 0; i < 5; i++)
            {
                <RadzenSkeleton Style="width: 100%; height: 36px;" Animation="SkeletonAnimation.Wave" />
            }
        </RadzenStack>
    </RadzenStack>
}

<div style="@(!_initialLoadComplete ? "visibility:hidden;overflow:hidden;height:0" : "")">

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center"
              class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="width: 51%;">
        <RadzenTextBox @ref="_searchBox" Value="@searchText"
                       @oninput="@OnSearchInput"
                       Placeholder="Search cases..." Style="width: 100%;" />
        <RadzenIcon Icon="info" Style="font-size: 20px; color: var(--rz-text-secondary-color); cursor: help;"
                    MouseEnter="@ShowSearchTooltip"
                    MouseLeave="@(_ => _tooltipService.Close())" />
    </RadzenStack>
    <RadzenButton Text="Create Case" Icon="add" ButtonStyle="ButtonStyle.Primary"
                  Variant="Variant.Outlined" Click="@OnCreateCase" />
</RadzenStack>

<RadzenDataGrid @ref="_grid" TItem="CaseListItemViewModel"
                Data="@cases"
                Count="@count"
                LoadData="@LoadData"
                IsLoading="@isLoading"
                SelectionMode="DataGridSelectionMode.Single"
                AllowRowSelectOnRowClick="true"
                @bind-Value="_selectedCases"
                CellContextMenu="@OnCellContextMenu"
                AllowSorting="true"
                AllowFiltering="true"
                AllowGrouping="true" 
                AllowColumnResize="true"
                FilterMode="FilterMode.Simple"
                PageSize="10" 
                AllowPaging="true"
                ShowPagingSummary="true"
                PagingSummaryFormat="@("Displaying page {0} of {1} ({2} records)")"
                PageSizeOptions="@(new[] { 5, 10, 25, 50 })"
                PagerHorizontalAlign="HorizontalAlign.Center"
                GridLines="DataGridGridLines.Both"
                class="rz-border-radius-2">
    <EmptyTemplate>
        <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" class="rz-py-12">
            <RadzenIcon Icon="list" Style="font-size: 48px; color: var(--rz-text-disabled-color);" />
            <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-secondary-color);">
                No cases yet. Click the Create Case button to start a new case.
            </RadzenText>
        </RadzenStack>
    </EmptyTemplate>
    <Columns>
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Title="" Width="55px" Sortable="false" Filterable="false" Resizable="false" Reorderable="false" Groupable="false" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @if (lodCase.IsCheckedOut)
                {
                    @if (string.Equals(lodCase.CheckedOutBy, _currentUserId, StringComparison.OrdinalIgnoreCase))
                    {
                        <RadzenIcon Icon="check_circle" Style="font-size: 16px; color: var(--rz-success);" title="Checked out by you" />
                    }
                    else
                    {
                        <RadzenIcon Icon="lock" class="checkout-lock-icon" Style="font-size: 16px;" title="@($"Checked out by {lodCase.CheckedOutByName}")" />
                    }
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="CaseId" Title="Case Number" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                <div class="case-id-cell">
                    <span class="case-id-link" @onclick="@(() => OnCaseClick(lodCase))">
                        @lodCase.CaseId
                    </span>
                    <RadzenButton ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Text"
                                  Size="ButtonSize.ExtraSmall"
                                  class="bookmark-btn"
                                  Click="@(() => ToggleBookmark(lodCase))"
                                  title="@(bookmarkedCaseIds.Contains(lodCase.Id) ? "Remove Bookmark" : "Add Bookmark")">
                        <ChildContent>
                            <span class="material-symbols-outlined @(animatingBookmarkIds.Contains(lodCase.Id) ? "bookmark-flash" : "")">@(animatingBookmarkIds.Contains(lodCase.Id) ? "bookmark_added" : bookmarkedCaseIds.Contains(lodCase.Id) ? "bookmark_remove" : "bookmark_add")</span>
                        </ChildContent>
                    </RadzenButton>
                </div>
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="ServiceNumber" Title="SSN" TextAlign="TextAlign.Center" Width="90px">
            <Template Context="lodCase">
                @if (!string.IsNullOrEmpty(lodCase.ServiceNumber) && lodCase.ServiceNumber.Length >= 4)
                {
                    @($"{lodCase.ServiceNumber[^4..]}")
                }
                else
                {
                    @lodCase.ServiceNumber
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="MemberName" Title="Member Name" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="MemberRank" Title="Rank" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="Unit" Title="Unit" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="CurrentWorkflowState" Title="Current Status" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @lodCase.CurrentWorkflowState.ToDisplayString()
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="IncidentType" Title="Injury Type" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @lodCase.IncidentType.ToDisplayString()
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="IncidentDate" Title="Date of Incident" FormatString="{0:yyyy-MM-dd}" TextAlign="TextAlign.Center" />
        <RadzenDataGridColumn TItem="CaseListItemViewModel" Property="ProcessType" Title="Process Type" TextAlign="TextAlign.Center">
            <Template Context="lodCase">
                @lodCase.ProcessType.ToDisplayString()
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

</div>
</div>
